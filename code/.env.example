DATABASE_URL="file:./dev.db"

# Public URL for RSVP links in emails (no trailing slash). Prefer full URL with scheme:
# https://events.yourcompany.com — required for correct links on a custom domain (VERCEL_URL
# alone points at *.vercel.app, not your CNAME).
APP_BASE_URL="http://localhost:3000"

# Optional: send RSVP invites via Resend (https://resend.com). If unset, organizers use “Copy link” on the roster.
RESEND_API_KEY=""
# Must be a sender Resend allows, e.g. MeetSync <onboarding@resend.dev> for testing
EMAIL_FROM="MeetSync <onboarding@resend.dev>"
