# PostgreSQL — required (schema does not support SQLite file:./ URLs).
#
# Local (no Docker): npm run db:up  then paste the URL prisma prints, e.g.:
DATABASE_URL="postgres://postgres:postgres@localhost:51214/template1?sslmode=disable&pgbouncer=true&connection_limit=1"
#
# Local (Docker): npm run db:up:docker  then:
# DATABASE_URL="postgresql://meetsync:meetsync@localhost:5432/meetsync"
#
# Hosted (Neon, Supabase, Vercel Postgres, etc.):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Public URL for RSVP links in emails (no trailing slash). Prefer full URL with scheme:
# https://events.yourcompany.com — required for correct links on a custom domain (VERCEL_URL
# alone points at *.vercel.app, not your CNAME).
APP_BASE_URL="http://localhost:3000"

# Auth — required on Vercel (min 32 random characters). Generate:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="replace-with-32-plus-random-characters-do-not-use-this-in-production"

# First admin user — local bootstrap only: npm run db:seed:admin
# This file is public on GitHub: placeholders only, never put real production passwords here.
ADMIN_EMAIL="ops@yourcompany.com"
ADMIN_PASSWORD="choose-a-strong-password-min-8-chars"
ADMIN_NAME="Ops Admin"

# Optional: send RSVP invites via Resend
RESEND_API_KEY=""
# Must be a sender Resend allows, e.g. MeetSync <onboarding@resend.dev> for testing
EMAIL_FROM="MeetSync <onboarding@resend.dev>"
