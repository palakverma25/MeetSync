generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  /** "admin" | "staff" */
  role         String   @default("staff")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([email])
}

model Event {
  id                  String     @id @default(cuid())
  title               String
  venue               String
  date                DateTime
  capacity            Int
  createdAt           DateTime   @default(now())
  attendees           Attendee[]

  @@index([date])
}

model Attendee {
  id                String    @id @default(cuid())
  eventId           String
  event             Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name              String
  phone             String
  /** Guest email — optional; used to send self-serve RSVP link */
  email             String?
  /** Opaque token for public /rsvp/[token] page; treat as secret */
  rsvpToken         String    @unique @default(uuid())
  dietaryPreference String    @default("")
  hasPlusOne        Boolean   @default(false)
  rsvpStatus        String    @default("confirmed")
  checkedInAt       DateTime?

  @@index([eventId])
  @@index([name])
  @@index([phone])
}
